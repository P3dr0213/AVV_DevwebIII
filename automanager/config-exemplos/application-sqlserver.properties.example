# ============================================================================
# 📋 EXEMPLO DE CONFIGURAÇÃO PARA SQL SERVER
# ============================================================================
#
# COMO USAR:
# 1. Descomente todas as linhas abaixo (remova o # do início)
# 2. Comente as configurações do H2 em application.properties
# 3. Configure os valores: host, porta, database, usuário, senha
# 4. Certifique-se de que SQL Server está rodando
# 5. Execute: mvn clean install && mvn spring-boot:run
#

# ============================================================================
# 🗄️  CONFIGURAÇÃO DO BANCO SQL SERVER
# ============================================================================
spring.datasource.url=jdbc:sqlserver://localhost:1433;databaseName=automanager
spring.datasource.driverClassName=com.microsoft.sqlserver.jdbc.SQLServerDriver
spring.datasource.username=sa
spring.datasource.password=sua_senha_sqlserver

# ============================================================================
# 🗄️  CONFIGURAÇÃO JPA/HIBERNATE
# ============================================================================
spring.jpa.database-platform=org.hibernate.dialect.SQLServer2012Dialect
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=false
spring.jpa.properties.hibernate.format_sql=false

# ============================================================================
# 🏊 POOL DE CONEXÕES (HIKARI) - OPCIONAL, MELHORA PERFORMANCE
# ============================================================================
spring.datasource.hikari.maximum-pool-size=10
spring.datasource.hikari.minimum-idle=5
spring.datasource.hikari.connection-timeout=30000
spring.datasource.hikari.idle-timeout=600000
spring.datasource.hikari.max-lifetime=1800000

# ============================================================================
# 📝 VALORES PADRÃO PARA CONFIGURAÇÃO
# ============================================================================
# Host: localhost (mesma máquina) ou IP do servidor SQL Server
# Porta: 1433 (padrão do SQL Server)
# Database: automanager (deve ser criado previamente)
# Usuário: sa (padrão - System Administrator) ou outro usuário
# Senha: senha definida na instalação do SQL Server
#
# EXEMPLO ALTERNATIVO (servidor remoto com autenticação Windows):
# spring.datasource.url=jdbc:sqlserver://SERVIDOR:1433;databaseName=automanager;integratedSecurity=true
# spring.datasource.driverClassName=com.microsoft.sqlserver.jdbc.SQLServerDriver
# (Neste caso, não precisa de usuário/senha se usar autenticação Windows)
#
# DIALETOS DISPONÍVEIS:
# - SQLServer2012Dialect (SQL Server 2012+) ← RECOMENDADO
# - SQLServer2016Dialect (SQL Server 2016+)
# - SQLServer2019Dialect (SQL Server 2019+)
